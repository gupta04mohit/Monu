generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  email            String            @unique
  passwordHash     String?
  googleId         String?
  name             String
  role             String            @default("USER")
  profile          Profile?
  digitalTwin      DigitalTwin?
  assessments      DoshaAssessment[]
  symptoms         Symptom[]
  predictions      HealthPrediction[]
  recommendations  Recommendation[]
  wellnessLogs     WellnessLog[]
  chatHistory      ChatHistory[]
  mealPlans        MealPlan[]
  gamification     Gamification?
  familyGroupId    String?           @db.ObjectId
  familyGroup      FamilyGroup?      @relation(fields: [familyGroupId], references: [id])
  wearableDevices  WearableDevice[]
  appointmentsAsPatient Appointment[] @relation("PatientAppointments")
  doctorProfile    DoctorProfile?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Profile {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  userId           String            @unique @db.ObjectId
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  age              Int?
  gender           String?
  weight           Float?            // in kg
  height           Float?            // in cm
  medicalHistory   String?
  primaryDosha     String?
  secondaryDosha   String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model DigitalTwin {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  userId           String            @unique @db.ObjectId
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentHealthScore Float           @default(100.0)
  sleepScore       Float             @default(100.0)
  stressLevel      String            @default("LOW") // LOW, MEDIUM, HIGH, BURNOUT
  burnoutRisk      Float             @default(0.0)
  futureHealthState String?          // AI prediction JSON
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model DoshaAssessment {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  userId           String            @db.ObjectId
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  vataScore        Int
  pittaScore       Int
  kaphaScore       Int
  primaryDosha     String
  secondaryDosha   String?
  healthTendencies String?           // JSON or Text
  createdAt        DateTime          @default(now())
}

model Symptom {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  userId           String            @db.ObjectId
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  symptomsList     String            // Comma separated or JSON
  severity         String
  aiAnalysis       String?           // AI response
  confidenceScore  Float?
  createdAt        DateTime          @default(now())
}

model HealthPrediction {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  userId           String            @db.ObjectId
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  diseaseName      String
  riskPercentage   Float
  riskCategory     String            // Low, Medium, High
  riskTimeline     String?           // e.g. "Within 1 year"
  preventiveMeasures String?         // JSON or Text
  createdAt        DateTime          @default(now())
}

model Recommendation {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  userId           String            @db.ObjectId
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type             String            // DIET, LIFESTYLE, EXERCISE, MENTAL
  content          String            // JSON payload detailing the recommendation
  basedOn          String            // e.g. "DOSHA", "SYMPTOMS"
  createdAt        DateTime          @default(now())
}

model MealPlan {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  userId           String            @db.ObjectId
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  planType         String            // DAILY, WEEKLY, MONTHLY
  meals            String            // JSON payload of recipes and schedules
  caloriesTarget   Int?
  createdAt        DateTime          @default(now())
}

model Gamification {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  userId           String            @unique @db.ObjectId
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  wellnessPoints   Int               @default(0)
  currentStreak    Int               @default(0)
  longestStreak    Int               @default(0)
  badges           String            // JSON array of badges
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model FamilyGroup {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  members          User[]
  createdAt        DateTime          @default(now())
}

model Herb {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  name             String            @unique
  botanicalName    String?
  benefits         String
  usage            String
  precautions      String?
  scientificStudies String?          // Links or references
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model WellnessLog {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  userId           String            @db.ObjectId
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  date             DateTime
  waterIntake      Float?            // Liters
  sleepHours       Float?
  meditationMins   Int?
  exerciseMins     Int?
  mood             String?
  healthScore      Float?            // Snapshot for the day
  createdAt        DateTime          @default(now())

  @@unique([userId, date])
}

model ChatHistory {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  userId           String            @db.ObjectId
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId        String
  role             String            // USER or AI
  message          String
  createdAt        DateTime          @default(now())
}

// ==========================================
// ENTERPRISE MODULES: WEARABLES & MARKETPLACE
// ==========================================

model WearableDevice {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  userId           String            @db.ObjectId
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform         String            // e.g., "APPLE_HEALTH", "FITBIT", "GOOGLE_FIT"
  accessToken      String?
  refreshToken     String?
  metrics          HealthMetric[]
  lastSyncedAt     DateTime?
  createdAt        DateTime          @default(now())
}

model HealthMetric {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  deviceId         String            @db.ObjectId
  device           WearableDevice    @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  metricType       String            // e.g., "HEART_RATE", "SPO2", "STEPS", "SLEEP_QUALITY"
  value            Float
  unit             String            // e.g., "bpm", "%", "count"
  timestamp        DateTime
  createdAt        DateTime          @default(now())
}

model DoctorProfile {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  userId           String            @unique @db.ObjectId
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialization   String            // e.g., "Ayurvedic Doctor", "Nutritionist"
  experienceYears  Int
  rating           Float             @default(0.0)
  consultationFee  Float
  bio              String?
  availableSlots   String            // JSON Array of availability
  appointments     Appointment[]     @relation("DoctorAppointments")
  createdAt        DateTime          @default(now())
}

model Appointment {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  patientId        String            @db.ObjectId
  patient          User              @relation("PatientAppointments", fields: [patientId], references: [id], onDelete: Cascade)
  doctorId         String            @db.ObjectId
  doctor           DoctorProfile     @relation("DoctorAppointments", fields: [doctorId], references: [id], onDelete: Cascade)
  scheduledAt      DateTime
  status           String            // PENDING, CONFIRMED, COMPLETED, CANCELLED
  meetingLink      String?
  prescription     String?           // JSON or Text
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}
